# Karpilo LoadIQ environment placeholders.
# Do not put real secrets in this file.
# Copy to .env.local for local runtime values. .env.local must remain gitignored.

# Public app/runtime configuration
NEXT_PUBLIC_APP_URL=https://app.example.test
NEXT_PUBLIC_BILLING_EMAIL=billing@example.test
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.test
NEXT_PUBLIC_EXECUTIVE_EMAIL=executive@example.test
NEXT_PUBLIC_SHOW_APP_COUNTDOWN=false
NEXT_PUBLIC_ENABLE_BILLING_TEST_HARNESS=false
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_VERSION=local

# Public Supabase browser configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-public-publishable-key

# Public observability configuration
NEXT_PUBLIC_POSTHOG_ENABLED=false
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=replace-with-public-posthog-token
NEXT_PUBLIC_POSTHOG_KEY=replace-with-public-posthog-token
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_AUTOCAPTURE=false
NEXT_PUBLIC_POSTHOG_SESSION_REPLAY=false
NEXT_PUBLIC_SENTRY_DSN=https://public@example.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_RELEASE=local

# Public map keys only when browser-safe and provider-restricted
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=replace-with-browser-restricted-key

# Server-only Supabase configuration
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key

# Server-only Stripe configuration
STRIPE_SECRET_KEY=replace-with-server-only-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-server-only-stripe-webhook-secret
STRIPE_PRICE_MONTHLY=replace-with-stripe-price-id
STRIPE_PRICE_ANNUAL=replace-with-stripe-price-id
STRIPE_PRICE_PILOT=replace-with-stripe-price-id
STRIPE_PRICE_PILOT_MONTHLY=replace-with-stripe-price-id
STRIPE_PRICE_PILOT_ANNUAL=replace-with-stripe-price-id
STRIPE_PRICE_LAUNCH500_MONTHLY=replace-with-stripe-price-id
STRIPE_PRICE_LAUNCH500_ANNUAL=replace-with-stripe-price-id

# Server-only provider keys
GOOGLE_MAPS_API_KEY=replace-with-server-only-google-maps-key
GOOGLE_WEATHER_API_KEY=replace-with-server-only-google-weather-key
GOOGLE_WEATHER_BASE_URL=https://weather.googleapis.com
OPENWEATHER_API_KEY=replace-with-server-only-openweather-key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/3.0
OPENAI_API_KEY=replace-with-server-only-openai-key
EIA_API_KEY=replace-with-server-only-eia-key
EIA_BASE_URL=https://api.eia.gov/v2
RESEND_API_KEY=replace-with-server-only-resend-key
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-server-only-upstash-token

# Server-side weather validation
NWS_BASE_URL=https://api.weather.gov
NWS_USER_AGENT=Karpilo LoadIQ local placeholder contact@example.test

# Server-only email and contact configuration
NO_REPLY_EMAIL=no-reply@example.test
SUPPORT_EMAIL=support@example.test
BILLING_EMAIL=billing@example.test
EXECUTIVE_EMAIL=executive@example.test
NEWSLETTER_EMAIL=newsletter@example.test
SECURITY_EMAIL=security@example.test
NOTIFICATIONS_EMAIL=notifications@example.test

# Server-only AI governance flags
ENABLE_LOADIQ_AI_DEV=false
LOADIQ_AI_MODEL=replace-with-approved-model-id
LOADIQ_AI_DISABLED=true
ATLAS_AI_DISABLED=true

# Server-only owner/admin build access
LOADIQ_OWNER_EMAILS=owner@example.test

# Server-only analytics and monitoring
POSTHOG_ENABLED=false
POSTHOG_PROJECT_TOKEN=replace-with-server-side-posthog-token
POSTHOG_HOST=https://app.posthog.com
POSTHOG_DASHBOARD_URL=https://app.posthog.com/project/example
SENTRY_DSN=https://public@example.ingest.sentry.io/0
SENTRY_ORG=replace-with-sentry-org
SENTRY_PROJECT=replace-with-sentry-project
SENTRY_AUTH_TOKEN=replace-with-server-only-sentry-auth-token
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=local
SENTRY_TRACES_SAMPLE_RATE=0

# Runtime labels
APP_ENV=local
