# Email routing examples only. Do not place API keys, DKIM, SPF, or DMARC
# records in this file.
SUPPORT_EMAIL=support@karpiloloadiq.com
BILLING_EMAIL=billing@karpiloloadiq.com
EXECUTIVE_EMAIL=j.karpilo@karpiloloadiq.com
NO_REPLY_EMAIL=noreply@karpiloloadiq.com
NEWSLETTER_EMAIL=newsletter@karpiloloadiq.com
SECURITY_EMAIL=security@karpiloloadiq.com
NOTIFICATIONS_EMAIL=notifications@karpiloloadiq.com

# Public display addresses only.
NEXT_PUBLIC_SUPPORT_EMAIL=support@karpiloloadiq.com
NEXT_PUBLIC_BILLING_EMAIL=billing@karpiloloadiq.com
NEXT_PUBLIC_EXECUTIVE_EMAIL=j.karpilo@karpiloloadiq.com

# Public app URL.
NEXT_PUBLIC_APP_URL=https://app.karpilo-liq.com

# Sentry error monitoring. Variable names only; do not commit real tokens.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.25

# PostHog product analytics. Keep disabled until consent/policy rollout is ready.
NEXT_PUBLIC_POSTHOG_ENABLED=false
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_AUTOCAPTURE=false
NEXT_PUBLIC_POSTHOG_SESSION_REPLAY=false
POSTHOG_ENABLED=false
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://us.i.posthog.com

# Redis / Upstash server-side cache.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenWeather server-side provider. Keep this out of public client bundles.
OPENWEATHER_API_KEY=
